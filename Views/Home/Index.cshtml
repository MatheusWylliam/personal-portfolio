@model MatheusWylliamPortfolio.Models.HomeViewModel

<nav class="navbar" id="navbar">
    <div class="navbar-inner">
        <a class="navbar-link" href="#inicio">@Model.Labels.NavStart</a>
        <a class="navbar-link" href="#sobre">@Model.Labels.NavAbout</a>
        <a class="navbar-link" href="#stack">@Model.Labels.NavStack</a>
        <a class="navbar-link" href="#experiencia">@Model.Labels.NavExperience</a>
        <a class="navbar-link" href="#projetos">@Model.Labels.NavProjects</a>
    </div>
    <div class="navbar-controls">
        <button class="theme-toggle" id="theme-toggle" onclick="toggleTheme()" title="Toggle theme">
            <span id="theme-icon">☀</span>
        </button>
        <div class="lang-toggle">
            <a href="?lang=pt" class="lang-btn @(Model.Lang == "pt" ? "lang-active" : "")">PT</a>
            <span style="color:var(--text-muted);">|</span>
            <a href="?lang=en" class="lang-btn @(Model.Lang == "en" ? "lang-active" : "")">EN</a>
        </div>
    </div>
</nav>

<div class="font-mono tracking-wide" style="max-width:820px;margin:0 auto;padding:0 2rem 4rem;">

  <section id="inicio" class="flex flex-col items-center justify-center" style="min-height:100vh;padding-top:5rem;">

    <div class="avatar-ring mb-6">
      <img src="/images/me.jpg" alt="Matheus Wylliam" style="width:112px;height:112px;object-fit:cover;" />
    </div>

    <p class="hello-text" style="font-size:0.78rem;letter-spacing:0.18em;text-transform:uppercase;">
      @Model.Labels.Hello
    </p>

    <h1 id="nome-h1">
      <span id="typewriter"></span><span id="cursor">|</span>
    </h1>

    <p style="font-size:0.875rem;color:var(--text-secondary);text-align:center;max-width:380px;line-height:1.8;">
      @Model.Labels.Headline
    </p>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-top:2.5rem;width:100%;max-width:380px;">

      <a href="https://github.com/MatheusWylliam" target="_blank" rel="noopener noreferrer" class="social-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        GitHub
      </a>

      <span class="social-btn social-btn-disabled">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </span>

      <a href="mailto:hazelramahz@icloud.com" class="social-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="20" height="16" x="2" y="4" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
        E-mail
      </a>

      <span class="social-btn social-btn-disabled">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
          <polyline points="10 9 9 9 8 9"/>
        </svg>
        @(Model.Lang == "pt" ? "Currículo" : "Resume")
      </span>

    </div>

    <div class="animate-bounce" style="margin-top:3.5rem;color:var(--text-muted);">
      <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>

  </section>

  <section id="sobre" style="padding-top:2rem;padding-bottom:2rem;">
    <p class="section-title">@Model.Labels.SectionAbout</p>
    <p style="font-size:0.9rem;line-height:2;color:var(--text-secondary);width:100%;" class="about-body">
      @Html.Raw(Model.Labels.AboutBody)
    </p>
  </section>

  <section id="stack" style="padding-top:2rem;padding-bottom:2rem;">
    <p class="section-title">@Model.Labels.SectionStack</p>
    <div class="marquee-wrapper" id="marquee-wrapper">
      <div class="marquee-track" id="marquee-track">
        <div class="stack-item"><img src="/icons/R-Dark.svg" alt="R" class="stack-icon" /><span class="stack-label">R</span></div>
        <div class="stack-item"><img src="/icons/Python-Dark.svg" alt="Python" class="stack-icon" /><span class="stack-label">Python</span></div>
        <div class="stack-item"><img src="/icons/ScikitLearn-Dark.svg" alt="Scikit-Learn" class="stack-icon" /><span class="stack-label">Scikit-Learn</span></div>
        <div class="stack-item"><img src="/icons/PyTorch-Dark.svg" alt="PyTorch" class="stack-icon" /><span class="stack-label">PyTorch</span></div>
        <div class="stack-item"><img src="/icons/CS.svg" alt="C#" class="stack-icon" /><span class="stack-label">C#</span></div>
        <div class="stack-item"><img src="/icons/DotNet.svg" alt=".NET" class="stack-icon" /><span class="stack-label">.NET</span></div>
        <div class="stack-item"><img src="/icons/CPP.svg" alt="C++" class="stack-icon" /><span class="stack-label">C++</span></div>
        <div class="stack-item"><img src="/icons/Arduino.svg" alt="Arduino" class="stack-icon" /><span class="stack-label">Arduino</span></div>
        <div class="stack-item"><img src="/icons/Terraform-Dark.svg" alt="Terraform" class="stack-icon" /><span class="stack-label">Terraform</span></div>
        <div class="stack-item"><img src="/icons/Docker.svg" alt="Docker" class="stack-icon" /><span class="stack-label">Docker</span></div>
        <div class="stack-item"><img src="/icons/PostgreSQL-Dark.svg" alt="PostgreSQL" class="stack-icon" /><span class="stack-label">PostgreSQL</span></div>
        <div class="stack-item"><img src="/icons/R-Dark.svg" alt="R" class="stack-icon" /><span class="stack-label">R</span></div>
        <div class="stack-item"><img src="/icons/Python-Dark.svg" alt="Python" class="stack-icon" /><span class="stack-label">Python</span></div>
        <div class="stack-item"><img src="/icons/ScikitLearn-Dark.svg" alt="Scikit-Learn" class="stack-icon" /><span class="stack-label">Scikit-Learn</span></div>
        <div class="stack-item"><img src="/icons/PyTorch-Dark.svg" alt="PyTorch" class="stack-icon" /><span class="stack-label">PyTorch</span></div>
        <div class="stack-item"><img src="/icons/CS.svg" alt="C#" class="stack-icon" /><span class="stack-label">C#</span></div>
        <div class="stack-item"><img src="/icons/DotNet.svg" alt=".NET" class="stack-icon" /><span class="stack-label">.NET</span></div>
        <div class="stack-item"><img src="/icons/CPP.svg" alt="C++" class="stack-icon" /><span class="stack-label">C++</span></div>
        <div class="stack-item"><img src="/icons/Arduino.svg" alt="Arduino" class="stack-icon" /><span class="stack-label">Arduino</span></div>
        <div class="stack-item"><img src="/icons/Terraform-Dark.svg" alt="Terraform" class="stack-icon" /><span class="stack-label">Terraform</span></div>
        <div class="stack-item"><img src="/icons/Docker.svg" alt="Docker" class="stack-icon" /><span class="stack-label">Docker</span></div>
        <div class="stack-item"><img src="/icons/PostgreSQL-Dark.svg" alt="PostgreSQL" class="stack-icon" /><span class="stack-label">PostgreSQL</span></div>
      </div>
    </div>
  </section>

  <section id="experiencia" style="padding-top:2rem;padding-bottom:2rem;">
    <p class="section-title">@Model.Labels.SectionExperience</p>
    <div style="display:flex;flex-direction:row;gap:0;">
      <ul style="display:flex;flex-direction:column;padding:0.5rem 0;margin:0;min-width:160px;list-style:none;">
        @for (int i = 0; i < Model.Experiences.Count; i++)
        {
          <li onclick="selectExpAndTrack(@i)" id="btn-exp-@i" class="exp-btn">
            @Model.Experiences[i].Company
          </li>
        }
      </ul>
      <div style="flex:1;padding:0.5rem 0 0.5rem 2rem;">
        @for (int i = 0; i < Model.Experiences.Count; i++)
        {
          <div id="exp-panel-@i" style="display:none;" class="exp-panel-inner">
            <h2 style="font-size:1rem;font-weight:600;margin-bottom:0.25rem;" class="exp-role-text">
              @Model.Experiences[i].Role
              <span class="exp-company-text">@("@") @Model.Experiences[i].Company</span>
            </h2>
            <div class="exp-period-text" style="font-size:0.72rem;letter-spacing:0.08em;margin-bottom:1.25rem;text-transform:uppercase;">
              @Model.Experiences[i].Period
            </div>
            <ul style="display:flex;flex-direction:column;gap:0.85rem;list-style:none;padding:0;margin:0;">
              @foreach (var bullet in Model.Experiences[i].Bullets)
              {
                <li style="display:flex;align-items:flex-start;gap:0.75rem;font-size:0.82rem;line-height:1.8;" class="exp-bullet-text">
                  <span class="exp-period-text" style="flex-shrink:0;margin-top:0.15rem;">▸</span>
                  <span>@bullet</span>
                </li>
              }
            </ul>
          </div>
        }
      </div>
    </div>
  </section>

  <section id="projetos" style="padding-top:2rem;padding-bottom:2rem;">
    <p class="section-title">@Model.Labels.SectionProjects</p>
    <div class="coming-soon-box">
      <p class="coming-soon-label">@Model.Labels.ComingSoon</p>
    </div>
  </section>

  <div class="divider"></div>

  <footer style="text-align:center;font-size:0.72rem;letter-spacing:0.08em;color:var(--text-muted);padding:1.5rem 0;line-height:2;">
    @{
      var footerParts = Model.Labels.FooterText.Split('|');
    }
    <div>@footerParts[0]</div>
    <div>@footerParts[1]</div>
  </footer>

</div>